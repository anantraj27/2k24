{
  "cleanUrls": true,

  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://twok24.onrender.com/:path*"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/home",
      "destination": "/home.html"
    },
    {
      "source": "/dashboard",
      "destination": "/scheduled-events.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/register",
      "destination": "/register.html"
    },
        {
      "source": "/events",
      "destination": "/events_.html"
    }
  
  ]
}